{
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/docs/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "functions": {
    "api/prerender.js": {
      "maxDuration": 10
    }
  }
}
